# ============================================================================
# Network selection
# ----------------------------------------------------------------------------
# This app runs against multiple networks from one codebase. Each network has
# its own env file, selected by the APP_NETWORK variable at build time:
#
#   .env.testnet         <- yarn dev:testnet         (also the default `yarn dev`)
#   .env.mainnet         <- yarn dev:mainnet          (X1 Mainnet)
#   .env.solana-mainnet  <- yarn dev:solana-mainnet   (Solana Mainnet)
#
# Build equivalents: yarn build:testnet / build:mainnet / build:solana-mainnet.
# Copy this file to the per-network file you need (e.g. .env.testnet) and fill
# in the values. All .env* files except this example are gitignored.
#
# Note: values you change in the app's Settings page are saved to localStorage,
# namespaced per network (e.g. x-rpc-url:testnet). Switching networks locally
# therefore no longer leaks one network's RPC/program override into another. An
# override you set for a given network persists for that network until changed.
#
# On Vercel, APP_NETWORK is unset and these APP_* vars come from the project's
# dashboard env settings instead of a file.
# ============================================================================

# Solana RPC URL
APP_RPC_URL=https://rpc.testnet.x1.xyz

# Squads Program ID
APP_PROGRAM_ID=DDL3Xp6ie85DXgiPkXJ7abUyS2tGv4CGEod2DeQXQ941

# Solana Explorer URL
APP_EXPLORER_URL=https://explorer.x1.xyz

# Pre-configured Saved Squads
# Format: APP_SAVED_SQUAD_<LABEL>=<ADDRESS>
# The label (after APP_SAVED_SQUAD_) will be converted from UPPER_SNAKE_CASE to Title Case
# Examples:
# APP_SAVED_SQUAD_DELEGATION_PROGRAM=X1DPvnLXekvd6EtDsPVqahzhziKx3Zj1z8WkD93xebg
# APP_SAVED_SQUAD_TREASURY_VAULT=7WbRWL33mM3pbFLvuqNjBztWBZMGc69Xbzg4sfxQ3KvP
# APP_SAVED_SQUAD_DAO_MULTISIG=9FgR2CfMbXfKiTn1HzaMXfMUxPXkxGoq8Zj3fUKkfRvC

# Stake Pool Configuration
# Configure stake pools by setting environment variables
# Format: REACT_APP_STAKE_POOL_<NUMBER>_<PROPERTY>
# You can configure up to 10 stake pools (1-10)

# Example for Pool 1:
APP_STAKE_POOL_X1_DELEGATION_PROGRAM_ADDRESS=X1SPaMUM1A8E1vKL8XQAB5rxKarJbqtWFFSNFs8f7Av
APP_STAKE_POOL_X1_DELEGATION_PROGRAM_MINT=pXNTyoqQsskHdZ7Q1rnP25FEyHHjissbs7n6RRN2nP5
APP_STAKE_POOL_X1_DELEGATION_PROGRAM_RESERVE=X1SPrgrATc3rCHCEDUPnAsFzhTaB6TTCesou6K4Q2kg
APP_STAKE_POOL_X1_DELEGATION_PROGRAM_NAME=X1 Delegation Pool

# Example for Pool 2:
# REACT_APP_STAKE_POOL_2_ADDRESS=<pool_address>
# REACT_APP_STAKE_POOL_2_MINT=<pool_mint_address>
# REACT_APP_STAKE_POOL_2_RESERVE=<reserve_stake_address>
# REACT_APP_STAKE_POOL_2_NAME=<pool_name>
